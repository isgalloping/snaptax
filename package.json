{
  "name": "snaptax",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/load-env.mjs && node scripts/migrate-deploy.mjs && prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "test:unit": "node --import tsx --test lib/**/*.test.ts",
    "postinstall": "prisma generate",
    "db:migrate:deploy": "node scripts/migrate-deploy.mjs",
    "db:migrate:deploy:production": "node scripts/migrate-deploy.mjs .env.production.local",
    "db:migrate:dev": "node scripts/load-env.mjs && npx prisma migrate dev",
    "db:studio": "node scripts/load-env.mjs && npx prisma studio"
  },
  "dependencies": {
    "@flags-sdk/vercel": "^1.4.0",
    "@paddle/paddle-js": "^1.6.4",
    "@prisma/client": "^6.19.3",
    "@types/archiver": "^8.0.0",
    "@types/pdfkit": "^0.17.6",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@vercel/blob": "^2.4.0",
    "archiver": "^8.0.0",
    "exceljs": "^4.4.0",
    "flags": "^4.1.0",
    "google-auth-library": "^10.7.0",
    "jose": "^6.2.3",
    "next": "16.2.7",
    "openai": "^6.42.0",
    "pdfkit": "^0.19.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "^0.34.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@serwist/turbopack": "^9.5.11",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "esbuild": "^0.28.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "playwright": "^1.49.1",
    "prisma": "^6.19.3",
    "serwist": "^9.5.11",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
